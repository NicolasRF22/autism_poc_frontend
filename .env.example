# URL base da API usada pelo frontend (inclua /api no final)
# Dev local com backend na mesma máquina:
VITE_API_BASE_URL=http://localhost:5000/api

# Target do proxy do Vite (apenas desenvolvimento)
# Usado por vite.config.js para encaminhar /api
VITE_DEV_PROXY_TARGET=http://localhost:5000

# Hosts permitidos no modo preview (ex.: Render)
VITE_PREVIEW_ALLOWED_HOSTS=autism-poc-frontend.onrender.com,localhost,127.0.0.1
